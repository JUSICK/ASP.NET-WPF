<Window x:Class="MyFullStackAppUi.AppUi"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lil APP :)" Height="450" Width="850">
    
    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="10">
            <TextBlock Text="1. Registration" FontWeight="Bold" FontSize="16" Margin="0,0,0,15" />
            
            <TextBlock Text="Username:" />
            <TextBox x:Name="txtRegUser" Margin="0,0,0,10" Height="25" />

            <TextBlock Text="E-mail:" />
            <TextBox x:Name="txtRegEmail" Margin="0,0,0,10" Height="25" />

            <TextBlock Text="Password:" />
            <PasswordBox x:Name="txtRegPass" Margin="0,0,0,15" Height="25" />

            <Button Content="Register" Height="35" Click="BtnRegister_Click" />
        </StackPanel>

        <StackPanel Grid.Column="1" Margin="10">
            <TextBlock Text="2. Login" FontWeight="Bold" FontSize="16" Margin="0,0,0,15" />
            
            <TextBlock Text="E-mail:" />
            <TextBox x:Name="txtLogEmail" Margin="0,0,0,10" Height="25" />

            <TextBlock Text="Password:" />
            <PasswordBox x:Name="txtLogPass" Margin="0,0,0,15" Height="25" />

            <Button Content="Login" Height="35" Click="BtnLogin_Click" Margin="0,0,0,15" />

            <TextBlock Text="JWT token:" Foreground="Gray" />
            <TextBox x:Name="txtTokenDisplay" Height="80" TextWrapping="Wrap" IsReadOnly="True" Background="#F0F0F0" />
        </StackPanel>

        <StackPanel Grid.Column="2" Margin="10">
            <TextBlock Text="3. Secured info" FontWeight="Bold" FontSize="16" Margin="0,0,0,15" />
            
            <TextBlock Text="Token is needed" Foreground="Gray" Margin="0,0,0,10" />
            
            <Button Content="Request info (Email)" Height="35" Click="BtnFetchData_Click" Margin="0,0,0,15" />
            

            <TextBlock Text="Server says:" />
            <Border BorderBrush="LightGray" BorderThickness="1" Height="50" Padding="5">
                <TextBlock x:Name="lblServerResponse" Text="..." VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" />
            </Border>
            <TextBlock x:Name="lblServerResponseMessage" Text="" VerticalAlignment="Center" HorizontalAlignment="Center" FontStyle="Italic" />
        </StackPanel>
        
    </Grid>
    
</Window>