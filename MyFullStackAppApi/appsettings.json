{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "MariaDbConnection": "Server=localhost;Port=YOUR_DB_PORT_HERE;Database=YOUR_DB_NAME_HERE;User=YOUR_DB_USER_HERE;Password=YOUR_DB_PASSWORD_HERE;"
  },
  "JwtSettings": {
    "Key": "YOUR_SUPER_SECRET_JWT_KEY_MIN_32_CHARS",
    "Issuer": "MyFullStackAppApi",
    "Audience": "MyFullStackAppApi_Client"
  }
}
